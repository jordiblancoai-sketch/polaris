{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://rip-backend.railway.app/api/v1/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
